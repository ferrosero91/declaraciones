# URL de conexión a PostgreSQL (Dokploy)
# Ejemplo local: postgresql://declaraciones:declaraciones@localhost:5432/declaraciones
DATABASE_URL=postgresql://user:password@host:port/database

# Activar SSL (true en producción si el host lo requiere)
DATABASE_SSL=false

# URL pública de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000